{
  "manifest_version": 3,
  "name": "BlurAway",
  "version": "1.0",
  "description": "Hide or blur profile pictures on LinkedIn for distraction-free browsing.",
  "permissions": [],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bluraway-2f8c7a1b@random",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}